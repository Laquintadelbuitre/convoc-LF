<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Convocations</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --pitch-dark:#12321f;
    --pitch:#1f5c3b;
    --green:#2f9e44;
    --green-dark:#237436;
    --red:#d62828;
    --red-dark:#a81f1f;
    --blue:#1d6fa5;
    --blue-dark:#155380;
    --amber:#e8a33d;
    --bg:#f4f6f2;
    --ink:#14231a;
    --card:#ffffff;
    --line:#e1e6dd;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg);
    color:var(--ink);
  }
  header.top{
    background:var(--pitch-dark);
    color:#fff;
    padding:18px 20px 46px;
    position:relative;
    overflow:hidden;
  }
  header.top::after{
    content:"";
    position:absolute;
    right:-60px; top:-60px;
    width:180px; height:180px;
    border:3px solid rgba(255,255,255,.12);
    border-radius:50%;
  }
  header.top::before{
    content:"";
    position:absolute;
    left:-40px; bottom:-80px;
    width:140px; height:140px;
    border:3px solid rgba(255,255,255,.08);
    border-radius:50%;
  }
  .title-row{
    display:flex; align-items:center; gap:10px;
    position:relative; z-index:1;
  }
  .title-row input{
    background:transparent;
    border:none;
    color:#fff;
    font-size:20px;
    font-weight:800;
    letter-spacing:.5px;
    text-transform:uppercase;
    width:100%;
    padding:4px 0;
    border-bottom:1px solid rgba(255,255,255,.25);
  }
  .title-row input:focus{outline:none; border-bottom-color:var(--amber);}
  .subtitle{
    font-size:12px;
    color:rgba(255,255,255,.6);
    margin-top:4px;
    position:relative; z-index:1;
  }
  nav.tabs{
    display:flex;
    gap:6px;
    margin:-30px 16px 0;
    position:relative;
    z-index:2;
  }
  nav.tabs button{
    flex:1;
    border:none;
    padding:12px 8px;
    font-size:13px;
    font-weight:700;
    letter-spacing:.3px;
    text-transform:uppercase;
    background:var(--card);
    color:#8b978f;
    border-radius:10px 10px 0 0;
    cursor:pointer;
  }
  nav.tabs button.active{
    background:var(--card);
    color:var(--pitch-dark);
    box-shadow:0 -2px 0 var(--amber) inset;
  }
  main{
    max-width:760px;
    margin:0 auto;
    padding:0 16px 60px;
  }
  .panel{
    background:var(--card);
    border-radius:0 0 12px 12px;
    padding:20px;
    box-shadow:0 1px 3px rgba(0,0,0,.06);
    margin-bottom:20px;
    display:none;
  }
  .panel.active{display:block;}
  h2{
    font-size:15px;
    text-transform:uppercase;
    letter-spacing:.5px;
    color:var(--pitch-dark);
    margin:0 0 14px;
  }
  h3{
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:.4px;
    margin:0 0 10px;
  }
  .field{margin-bottom:12px;}
  .field label{
    display:block;
    font-size:12px;
    color:#6b756e;
    margin-bottom:4px;
    font-weight:600;
  }
  .field input, .field select{
    width:100%;
    padding:9px 10px;
    border:1px solid var(--line);
    border-radius:8px;
    font-size:14px;
    font-family:inherit;
  }
  .field input:focus, .field select:focus{outline:2px solid var(--amber); border-color:transparent;}
  .row2{display:flex; gap:10px;}
  .row2 > div{flex:1;}
  .btn{
    display:inline-block;
    border:none;
    padding:10px 18px;
    border-radius:8px;
    font-size:13px;
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:.3px;
    cursor:pointer;
  }
  .btn-primary{background:var(--pitch-dark); color:#fff;}
  .btn-amber{background:var(--amber); color:#1a1a1a;}
  .btn-primary:hover{background:var(--pitch);}
  .list-item{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:10px 12px;
    border:1px solid var(--line);
    border-radius:8px;
    margin-bottom:8px;
    font-size:14px;
  }
  .list-item .meta{color:#7a847d; font-size:12px; margin-top:2px;}
  .del{
    background:none; border:none; color:#b23; font-size:18px; cursor:pointer; padding:0 4px;
    line-height:1;
  }
  .empty{
    color:#8b978f;
    font-size:13px;
    text-align:center;
    padding:20px 0;
  }
  .team-block{
    border:1px solid var(--line);
    border-radius:10px;
    padding:14px;
    margin-bottom:14px;
  }
  .team-block.a{border-left:4px solid var(--green);}
  .team-block.b{border-left:4px solid var(--red);}
  .chips{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top:6px;
  }
  .chip{
    position:relative;
    padding:9px 26px 9px 14px;
    border-radius:20px;
    font-size:14px;
    font-weight:700;
    cursor:pointer;
    user-select:none;
    background:var(--red);
    color:#fff;
  }
  .chip.state-A{background:var(--green);}
  .chip.state-blesse{background:var(--blue);}
  .chip .star{
    position:absolute;
    top:1px; right:3px;
    font-size:13px;
    line-height:1;
    padding:2px;
    cursor:pointer;
    opacity:.55;
  }
  .chip .star.on{opacity:1; color:#ffe08a;}
  .match-info{
    display:flex;
    gap:10px;
    margin-bottom:16px;
  }
  .match-info .card{
    flex:1;
    border-radius:10px;
    padding:12px;
    color:#fff;
    font-size:13px;
  }
  .match-info .card.a{background:var(--green-dark);}
  .match-info .card.b{background:var(--red-dark);}
  .match-info .card b{display:block; font-size:14px; margin-bottom:2px;}
  .hint{font-size:12px; color:#7a847d; margin:10px 0 16px;}
  .legend{display:flex; gap:14px; font-size:12px; color:#556; margin-bottom:14px; flex-wrap:wrap;}
  .legend span{display:inline-flex; align-items:center; gap:5px;}
  .dot{width:10px;height:10px;border-radius:50%; display:inline-block;}
  #canvasWrap{text-align:center; margin-top:16px;}
  #canvasWrap .imgBlock{margin-bottom:24px;}
  #canvasWrap canvas{max-width:100%; border-radius:8px; box-shadow:0 2px 8px rgba(0,0,0,.15);}
  .actions{display:flex; gap:10px; margin-top:16px; flex-wrap:wrap;}
  .save-link{display:inline-block; margin-top:12px;}
  .toast{
    position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
    background:var(--ink); color:#fff; padding:10px 18px; border-radius:8px;
    font-size:13px; opacity:0; pointer-events:none; transition:opacity .25s;
    z-index:50;
  }
  .toast.show{opacity:1;}
</style>
</head>
<body>

<header class="top">
  <div class="title-row">
    <input id="clubTitle" value="U13 Limoges Football" maxlength="40">
  </div>
  <div class="subtitle">Convocations hebdomadaires</div>
</header>

<nav class="tabs">
  <button class="active" data-tab="effectif">Effectif</button>
  <button data-tab="calendrier">Calendrier</button>
  <button data-tab="convocation">Convocation</button>
</nav>

<main>

  <section class="panel active" id="panel-effectif">
    <h2>Liste des enfants</h2>
    <div class="field">
      <label>Nom de l'enfant</label>
      <div class="row2">
        <input id="childName" placeholder="Prénom Nom" maxlength="40">
        <div style="flex:0 0 auto;"><button class="btn btn-primary" id="addChildBtn">Ajouter</button></div>
      </div>
    </div>
    <div id="childList"></div>
  </section>

  <section class="panel" id="panel-calendrier">
    <h2>Ajouter une rencontre</h2>
    <div class="row2">
      <div class="field">
        <label>Libellé (ex. Journée 5)</label>
        <input id="matchLabel" placeholder="Journée 5" maxlength="30">
      </div>
      <div class="field">
        <label>Date</label>
        <input id="matchDate" type="date">
      </div>
    </div>

    <h3 style="color:var(--green-dark);">Équipe A</h3>
    <div class="row2">
      <div class="field"><label>Adversaire (après "VS")</label><input id="advA" placeholder="Bessines (match en retard)"></div>
      <div class="field"><label>Heure du RDV</label><input id="heureA" placeholder="14h15"></div>
    </div>
    <div class="row2">
      <div class="field"><label>Lieu du RDV</label><input id="lieuA" placeholder="Stade J.M Lafond"></div>
      <div class="field"><label>Adresse</label><input id="adresseA" placeholder="2 avenue de..., 87250 Bessines"></div>
    </div>

    <h3 style="color:var(--red-dark); margin-top:18px;">Équipe B</h3>
    <div class="row2">
      <div class="field"><label>Adversaire (après "VS")</label><input id="advB" placeholder="Tournoi Moulins Yzeure"></div>
      <div class="field"><label>Heure du RDV</label><input id="heureB" placeholder="7h00"></div>
    </div>
    <div class="row2">
      <div class="field"><label>Lieu du RDV</label><input id="lieuB" placeholder="Parking du McDonald's"></div>
      <div class="field"><label>Adresse</label><input id="adresseB" placeholder="Centre Commercial Cora, 87280 Limoges"></div>
    </div>

    <button class="btn btn-primary" id="addMatchBtn">Ajouter la rencontre</button>

    <h2 style="margin-top:28px;">Rencontres de la saison</h2>
    <div id="matchList"></div>
  </section>

  <section class="panel" id="panel-convocation">
    <h2>Sélection de la rencontre</h2>
    <div class="field">
      <select id="matchSelect"></select>
    </div>

    <div id="matchInfoBox"></div>

    <div id="convocationBody"></div>

    <div class="actions">
      <button class="btn btn-amber" id="generateBtn">Générer les images</button>
    </div>

    <div id="canvasWrap"></div>
  </section>

</main>

<div class="toast" id="toast"></div>

<script>
const ASSETS = {
  bg: "data:image/jpeg;base64,",
  logo: "data:image/png;base64,",
  photoTop: "data:image/png;base64,",
  photoBottom: "data:image/jpeg;base64,"
};

const store = window.storage;
let children = [];
let matches = [];
let currentMatchId = null;
let assignments = {}; // { childId: {team:'A'|'B'|'blesse', mute:bool} }

function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 1800);
}

function uid(){ return Date.now().toString(36) + Math.random().toString(36).slice(2,7); }

// ---------- persistence ----------
const DEFAULT_ROSTER = ["Hadi","Sebastien","Mickaël","Bakoutoubo","Sacha","Keys","Nourou","Yanis","Mathis","Ethan","Abdoul Karim","Jalil","Gabin","Adam","Kalifa","Bilel","Pablo","Melih","Issam","Emir","Loan","Sarah"];

async function loadAll(){
  try{
    const c = await store.get('effectif', false);
    if(c){
      children = JSON.parse(c.value);
    } else {
      children = DEFAULT_ROSTER.map(name => ({id: uid(), name}));
      await store.set('effectif', JSON.stringify(children), false);
    }
  }catch(e){ children = []; }
  try{
    const m = await store.get('calendrier', false);
    matches = m ? JSON.parse(m.value) : [];
  }catch(e){ matches = []; }
  try{
    const title = await store.get('titre', false);
    if(title) document.getElementById('clubTitle').value = title.value;
  }catch(e){}
}

async function saveChildren(){
  try{ await store.set('effectif', JSON.stringify(children), false); }
  catch(e){ toast("Erreur d'enregistrement"); }
}
async function saveMatches(){
  try{ await store.set('calendrier', JSON.stringify(matches), false); }
  catch(e){ toast("Erreur d'enregistrement"); }
}
async function saveTitle(){
  try{ await store.set('titre', document.getElementById('clubTitle').value, false); }
  catch(e){}
}
async function loadAssignments(matchId){
  try{
    const r = await store.get('conv_' + matchId, false);
    assignments = r ? JSON.parse(r.value) : {};
  }catch(e){ assignments = {}; }
}
async function saveAssignments(){
  if(!currentMatchId) return;
  try{ await store.set('conv_' + currentMatchId, JSON.stringify(assignments), false); }
  catch(e){ toast("Erreur d'enregistrement"); }
}

// ---------- tabs ----------
document.querySelectorAll('nav.tabs button').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
    if(btn.dataset.tab === 'convocation'){ renderMatchSelect(); }
  });
});

document.getElementById('clubTitle').addEventListener('change', saveTitle);

// ---------- effectif ----------
function renderChildren(){
  const box = document.getElementById('childList');
  if(children.length === 0){
    box.innerHTML = '<div class="empty">Aucun enfant ajouté pour l\'instant.</div>';
    return;
  }
  box.innerHTML = children.map(c => `
    <div class="list-item">
      <span>${escapeHtml(c.name)}</span>
      <button class="del" data-id="${c.id}" title="Supprimer">×</button>
    </div>
  `).join('');
  box.querySelectorAll('.del').forEach(b=>{
    b.addEventListener('click', ()=>{
      children = children.filter(c=>c.id !== b.dataset.id);
      saveChildren();
      renderChildren();
    });
  });
}

document.getElementById('addChildBtn').addEventListener('click', ()=>{
  const input = document.getElementById('childName');
  const name = input.value.trim();
  if(!name) return;
  children.push({id: uid(), name});
  input.value = '';
  saveChildren();
  renderChildren();
});
document.getElementById('childName').addEventListener('keydown', e=>{
  if(e.key === 'Enter') document.getElementById('addChildBtn').click();
});

// ---------- calendrier ----------
function renderMatches(){
  const box = document.getElementById('matchList');
  if(matches.length === 0){
    box.innerHTML = '<div class="empty">Aucune rencontre programmée.</div>';
    return;
  }
  const sorted = [...matches].sort((a,b)=> (a.date||'').localeCompare(b.date||''));
  box.innerHTML = sorted.map(m => `
    <div class="list-item">
      <div>
        <div><b>${escapeHtml(m.label || ('VS ' + m.A.adversaire))}</b> ${m.date ? '— ' + formatDate(m.date) : ''}</div>
        <div class="meta">A: VS ${escapeHtml(m.A.adversaire||'—')} · ${escapeHtml(m.A.heure||'—')} &nbsp;|&nbsp; B: VS ${escapeHtml(m.B.adversaire||'—')} · ${escapeHtml(m.B.heure||'—')}</div>
      </div>
      <button class="del" data-id="${m.id}" title="Supprimer">×</button>
    </div>
  `).join('');
  box.querySelectorAll('.del').forEach(b=>{
    b.addEventListener('click', ()=>{
      matches = matches.filter(m=>m.id !== b.dataset.id);
      saveMatches();
      renderMatches();
    });
  });
}

function formatDate(iso){
  const d = new Date(iso + 'T00:00:00');
  if(isNaN(d)) return iso;
  let s = d.toLocaleDateString('fr-FR', {weekday:'long', day:'2-digit', month:'long', year:'numeric'});
  return s.charAt(0).toUpperCase() + s.slice(1);
}

document.getElementById('addMatchBtn').addEventListener('click', ()=>{
  const label = document.getElementById('matchLabel').value.trim();
  const date = document.getElementById('matchDate').value;
  const A = {
    adversaire: document.getElementById('advA').value.trim(),
    heure: document.getElementById('heureA').value.trim(),
    lieu: document.getElementById('lieuA').value.trim(),
    adresse: document.getElementById('adresseA').value.trim()
  };
  const B = {
    adversaire: document.getElementById('advB').value.trim(),
    heure: document.getElementById('heureB').value.trim(),
    lieu: document.getElementById('lieuB').value.trim(),
    adresse: document.getElementById('adresseB').value.trim()
  };
  if(!A.adversaire && !B.adversaire){ toast('Indique au moins un adversaire'); return; }
  matches.push({id: uid(), label, date, A, B});
  ['matchLabel','advA','heureA','lieuA','adresseA','advB','heureB','lieuB','adresseB'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('matchDate').value='';
  saveMatches();
  renderMatches();
});

// ---------- convocation ----------
function renderMatchSelect(){
  const sel = document.getElementById('matchSelect');
  const sorted = [...matches].sort((a,b)=> (a.date||'').localeCompare(b.date||''));
  if(sorted.length === 0){
    sel.innerHTML = '<option>Aucune rencontre — ajoute-en une dans Calendrier</option>';
    document.getElementById('matchInfoBox').innerHTML = '';
    document.getElementById('convocationBody').innerHTML = '';
    return;
  }
  sel.innerHTML = sorted.map(m => `<option value="${m.id}">${escapeHtml(m.label || ('VS ' + m.A.adversaire))}${m.date ? ' — ' + formatDate(m.date) : ''}</option>`).join('');
  if(!currentMatchId || !matches.find(m=>m.id===currentMatchId)){
    currentMatchId = sorted[0].id;
  }
  sel.value = currentMatchId;
  onMatchChange();
}

document.getElementById('matchSelect').addEventListener('change', e=>{
  currentMatchId = e.target.value;
  onMatchChange();
});

async function onMatchChange(){
  document.getElementById('canvasWrap').innerHTML = '';
  await loadAssignments(currentMatchId);
  renderMatchInfo();
  renderConvocationBody();
}

function renderMatchInfo(){
  const m = matches.find(x=>x.id === currentMatchId);
  const box = document.getElementById('matchInfoBox');
  if(!m){ box.innerHTML=''; return; }
  box.innerHTML = `
    <div class="match-info">
      <div class="card a"><b>VS ${escapeHtml(m.A.adversaire||'—')}</b>${escapeHtml(m.A.heure||'—')} · ${escapeHtml(m.A.lieu||'—')}</div>
      <div class="card b"><b>VS ${escapeHtml(m.B.adversaire||'—')}</b>${escapeHtml(m.B.heure||'—')} · ${escapeHtml(m.B.lieu||'—')}</div>
    </div>
  `;
}

function renderConvocationBody(){
  const box = document.getElementById('convocationBody');
  if(children.length === 0){
    box.innerHTML = '<div class="empty">Ajoute d\'abord des enfants dans l\'onglet Effectif.</div>';
    return;
  }
  box.innerHTML = `
    <div class="legend">
      <span><span class="dot" style="background:var(--red)"></span>Équipe B (par défaut)</span>
      <span><span class="dot" style="background:var(--green)"></span>Équipe A</span>
      <span><span class="dot" style="background:var(--blue)"></span>Blessé</span>
      <span>★ Joueur muté (clic sur l'étoile)</span>
    </div>
    <div class="hint">Clic sur le nom = bascule Équipe A / Équipe B. Clic droit = blessé.</div>
    <div class="chips" id="chipBox"></div>
  `;
  renderChips();
}

function getAssign(id){
  return assignments[id] || {team:'B', mute:false};
}

function renderChips(){
  const chipBox = document.getElementById('chipBox');
  chipBox.innerHTML = children.map(c=>{
    const a = getAssign(c.id);
    const cls = a.team === 'A' ? 'state-A' : (a.team === 'blesse' ? 'state-blesse' : '');
    return `<div class="chip ${cls}" data-id="${c.id}">${escapeHtml(c.name)}<span class="star ${a.mute?'on':''}" data-id="${c.id}">★</span></div>`;
  }).join('');

  chipBox.querySelectorAll('.chip').forEach(chip=>{
    chip.addEventListener('click', (e)=>{
      if(e.target.classList.contains('star')) return;
      const id = chip.dataset.id;
      const a = getAssign(id);
      if(a.team === 'blesse') return;
      assignments[id] = {team: a.team === 'A' ? 'B' : 'A', mute: a.mute};
      saveAssignments();
      renderChips();
    });
    chip.addEventListener('contextmenu', e=>{
      e.preventDefault();
      const id = chip.dataset.id;
      const a = getAssign(id);
      assignments[id] = {team: a.team === 'blesse' ? 'B' : 'blesse', mute: a.mute};
      saveAssignments();
      renderChips();
    });
  });
  chipBox.querySelectorAll('.star').forEach(star=>{
    star.addEventListener('click', (e)=>{
      e.stopPropagation();
      const id = star.dataset.id;
      const a = getAssign(id);
      assignments[id] = {team: a.team, mute: !a.mute};
      saveAssignments();
      renderChips();
    });
  });
}

function escapeHtml(s){
  return (s||'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ---------- image generation ----------
document.getElementById('generateBtn').addEventListener('click', async ()=>{
  const m = matches.find(x=>x.id === currentMatchId);
  if(!m){ toast('Sélectionne une rencontre'); return; }

  try{
    await document.fonts.load('700 32px "Roboto Condensed"');
    await document.fonts.load('400 32px "Roboto Condensed"');
    await document.fonts.ready;
  }catch(e){}

  const wrap = document.getElementById('canvasWrap');
  wrap.innerHTML = '';

  const teamAPlayers = children.filter(c => getAssign(c.id).team === 'A');
  const teamBPlayers = children.filter(c => getAssign(c.id).team === 'B');

  await renderConvocationImage(m, 'A', teamAPlayers, wrap);
  await renderConvocationImage(m, 'B', teamBPlayers, wrap);
});

function loadImage(src){
  return new Promise((resolve,reject)=>{
    const img = new Image();
    img.onload = ()=>resolve(img);
    img.onerror = reject;
    img.src = src;
  });
}

async function renderConvocationImage(m, teamKey, players, wrap){
  const info = m[teamKey];
  const W = 1600, H = 900;
  const canvas = document.createElement('canvas');
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');

  const [bg, logo, photoTop, photoBottom] = await Promise.all([
    loadImage(ASSETS.bg), loadImage(ASSETS.logo), loadImage(ASSETS.photoTop), loadImage(ASSETS.photoBottom)
  ]);

  // background
  ctx.drawImage(bg, 0, 0, W, H);

  // logo
  ctx.drawImage(logo, 37, 19, 187, 187);

  // photos
  ctx.drawImage(photoTop, 1184, 185, 349, 313);
  ctx.drawImage(photoBottom, 1187, 525, 346, 328);

  const navy = '#2C2D4A';
  const bodyColor = '#403B48';
  const condensed = '"Roboto Condensed", "Arial Narrow", sans-serif';
  const displayFont = '"Arial Black", Arial, sans-serif';

  // title: Convocatoria : VS {adversaire}
  ctx.fillStyle = navy;
  ctx.textBaseline = 'alphabetic';
  ctx.textAlign = 'center';
  const titleText = `Convocatoria : VS ${info.adversaire || ''}`;
  drawWrappedTitle(ctx, titleText, 224 + 866.5/2, 14, 866.5, 52, `800 46px ${displayFont}`);

  // "Liste de N joueurs :"
  const n = players.length;
  ctx.font = `800 46px ${displayFont}`;
  ctx.fillStyle = navy;
  ctx.textAlign = 'center';
  ctx.fillText(`Liste de ${n} joueur${n>1?'s':''} :`, 224 + 866.5/2, 215 + 42);

  // players list, 2 columns, column-major
  ctx.textAlign = 'left';
  const listX = 224, listY = 353 + 40, colWidth = 433, rowH = 44;
  const cols = 2;
  const rows = Math.ceil(players.length / cols) || 1;
  const anyMute = players.some(p => getAssign(p.id).mute);
  ctx.font = `400 30px ${condensed}`;
  players.forEach((p, i)=>{
    const col = Math.floor(i / rows);
    const row = i % rows;
    const x = listX + col * colWidth;
    const y = listY + row * rowH;
    const a = getAssign(p.id);
    const label = `${i+1}. ${p.name}`;
    ctx.fillStyle = bodyColor;
    ctx.fillText(label, x, y);
    if(a.mute){
      const w = ctx.measureText(label).width;
      ctx.fillStyle = '#FF0000';
      ctx.font = `700 30px ${condensed}`;
      ctx.fillText(' *', x + w, y);
      ctx.font = `400 30px ${condensed}`;
    }
  });

  // muted legend
  if(anyMute){
    ctx.textAlign = 'center';
    ctx.font = `700 24px ${condensed}`;
    const legendY = 566 + 20;
    const star = '*';
    const rest = ' = Joueur Muté';
    const totalW = ctx.measureText(star).width + ctx.measureText(rest).width;
    const startX = 316 + 866.5/2 - totalW/2;
    ctx.textAlign = 'left';
    ctx.fillStyle = '#FF0000';
    ctx.fillText(star, startX, legendY);
    ctx.fillStyle = navy;
    ctx.fillText(rest, startX + ctx.measureText(star).width, legendY);
  }

  // bottom info box text (white, over navy baked into bg)
  const infoX = 88, infoW = 456;
  let iy = 657 + 30;
  ctx.textAlign = 'left';
  ctx.fillStyle = '#ffffff';
  ctx.font = `700 27px ${condensed}`;
  ctx.fillText(m.date ? formatDate(m.date) : '', infoX, iy);
  iy += 46;
  ctx.font = `700 27px ${condensed}`;
  const rdvLine = `RDV ${info.heure || '—'} au ${info.lieu || '—'}`;
  iy = drawWrapped(ctx, rdvLine, infoX, iy, infoW, 32) + 14;
  ctx.font = `400 24px ${condensed}`;
  ctx.fillStyle = 'rgba(255,255,255,.9)';
  drawWrapped(ctx, info.adresse || '', infoX, iy, infoW, 28);

  // footer
  ctx.textAlign = 'center';
  ctx.font = `italic 700 24px ${condensed}`;
  ctx.fillStyle = 'rgba(255,255,255,.55)';
  ctx.fillText("Merci d'informer systématiquement du retard ou de l'absence de votre enfant", 408 + 866.5/2, 859 + 20);

  const block = document.createElement('div');
  block.className = 'imgBlock';
  const h3 = document.createElement('div');
  h3.style.fontWeight='700';
  h3.style.marginBottom='6px';
  h3.style.color = teamKey === 'A' ? '#237436' : '#a81f1f';
  h3.textContent = 'Équipe ' + teamKey;
  block.appendChild(h3);
  block.appendChild(canvas);
  const link = document.createElement('a');
  link.className = 'btn btn-primary save-link';
  link.textContent = "Télécharger l'image Équipe " + teamKey;
  link.href = canvas.toDataURL('image/png');
  link.download = `convocation-equipe-${teamKey}-${(m.label||'match').replace(/\s+/g,'_')}.png`;
  block.appendChild(document.createElement('br'));
  block.appendChild(link);
  wrap.appendChild(block);
}

function drawWrappedTitle(ctx, text, cx, y, maxWidth, lineHeight, font){
  ctx.font = font;
  const words = text.split(' ');
  let lines = [];
  let cur = '';
  words.forEach(w=>{
    const test = cur ? cur + ' ' + w : w;
    if(ctx.measureText(test).width > maxWidth && cur){
      lines.push(cur);
      cur = w;
    } else {
      cur = test;
    }
  });
  if(cur) lines.push(cur);
  ctx.textAlign = 'center';
  lines.forEach((line, i)=>{
    ctx.fillText(line, cx, y + lineHeight*(i+1));
  });
}

function drawWrapped(ctx, text, x, y, maxWidth, lineHeight){
  const words = (text||'').split(' ');
  let lines = [];
  let cur = '';
  words.forEach(w=>{
    const test = cur ? cur + ' ' + w : w;
    if(ctx.measureText(test).width > maxWidth && cur){
      lines.push(cur);
      cur = w;
    } else {
      cur = test;
    }
  });
  if(cur) lines.push(cur);
  lines.forEach((line, i)=>{
    ctx.fillText(line, x, y + lineHeight*i);
  });
  return y + lineHeight*lines.length;
}

// ---------- init ----------
(async function init(){
  await loadAll();
  renderChildren();
  renderMatches();
  renderMatchSelect();
})();
</script>
